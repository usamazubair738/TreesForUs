<% content_for :title, "Family memberships" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Family memberships</h1>
    <%= link_to "New family membership", new_family_membership_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white block font-medium" %>
  </div>

  <div id="family_memberships" class="min-w-full">
    <% if @family_memberships.any? %>
      <% @family_memberships.each do |family_membership| %>
        <%= render family_membership %>
        <p>
          <%= link_to "Show this family membership", family_membership, class: "ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
        </p>
      <% end %>
    <% else %>
      <p class="text-center my-10">No family memberships found.</p>
    <% end %>
  </div>
</div>
