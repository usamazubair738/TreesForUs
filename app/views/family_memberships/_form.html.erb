<%= form_with(model: family_membership, class: "contents") do |form| %>
  <% if family_membership.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(family_membership.errors.count, "error") %> prohibited this family_membership from being saved:</h2>

      <ul class="list-disc ml-6">
        <% family_membership.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :user_id %>
    <%= form.text_field :user_id, class: ["block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": family_membership.errors[:user_id].none?, "border-red-400 focus:outline-red-600": family_membership.errors[:user_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :family_id %>
    <%= form.text_field :family_id, class: ["block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": family_membership.errors[:family_id].none?, "border-red-400 focus:outline-red-600": family_membership.errors[:family_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :membership_type %>
    <%= form.number_field :membership_type, class: ["block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": family_membership.errors[:membership_type].none?, "border-red-400 focus:outline-red-600": family_membership.errors[:membership_type].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
