doctype html
html
  head
    = csrf_meta_tags
    = csp_meta_tag

  body.bg-gray-100.min-h-screen.flex.items-center.justify-center

    .w-full.max-w-md.bg-white.rounded-2xl.shadow-xl.p-10

      - if flash[:notice]
        p.flash-message.bg-green-100.border-l-4.border-green-500.text-green-700.p-4.rounded.mb-4
          = flash[:notice]

      - if flash[:alert]
        p.flash-message.bg-red-100.border-l-4.border-red-500.text-red-700.p-4.rounded.mb-4
          = flash[:alert]

      .flex.flex-col.items-center.justify-center.text-center

        = image_tag "logo.png", class: "w-20 h-20 mb-5"

        h1.text-3xl.font-bold.text-green-900.mb-2
          | Trees For Us

        p.text-green-900.mb-2
          | Discover. Connect. Belong.

        p.text-gray-900.text-sm.mb-6
          | Visualize your family. Explore your roots.
          br
          | Build your legacy for generations.

      - identification_options = [["Passport", "passport"], ["Driver's License", "drivers_license"], ["National ID", "national_id"]]
      - membership_options = [["Birth Family", "birth"], ["Marriage Family", "marriage"]]
      - marital_status_options = [["Single", "single"], ["Married", "married"], ["Divorced", "divorced"], ["Widowed", "widowed"]]

      = form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f|

        .space-y-4

          / BASIC INFO

          = f.text_field :first_name,
            required: true,
            placeholder: "First Name",
            class: "w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500"

          = f.text_field :last_name,
            required: true,
            placeholder: "Last Name",
            class: "w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500"

          = f.email_field :email,
            required: true,
            placeholder: "Email Address",
            class: "w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500"

          = f.password_field :password,
            required: true,
            placeholder: "Password",
            class: "w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500"

          = f.password_field :password_confirmation,
            required: true,
            placeholder: "Confirm Password",
            class: "w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500"

          / PROFILE INFO

          = f.fields_for :user_profile_attributes do |p|

            = p.date_field :birth_date,
              required: true,
              class: "w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500"

            = p.select :marital_status,
              options_for_select(marital_status_options),
              { prompt: "Select Marital Status" },
              class: "w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500"

          / IDENTIFICATION

          = f.select :identification_type,
            options_for_select(identification_options, resource.identification_type),
            { prompt: "Select Identification Type" },
            class: "w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500"

          = f.text_field :identification_number,
            required: true,
            placeholder: "Identification Number",
            class: "w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500"

          / FAMILY SECTION
          / FAMILY SECTION

          = select_tag :family_id,
            options_from_collection_for_select(Family.all, :id, :name),
            prompt: "Select Existing Family",
            class: "w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500",
            id: "family_select"

          .text-center.text-gray-500.font-semibold
            | OR

          = text_field_tag :new_family_name,
            nil,
            placeholder: "Create New Family",
            class: "w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500",
            id: "new_family_input"

          = select_tag :membership_type,
            options_for_select([["Birth Family", "birth"], ["Marriage Family", "marriage"]]),
            prompt: "Select Membership Type",
            class: "w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500",
            required: true
          - if @minimum_password_length
            p.text-xs.text-gray-500.text-center
              = "#{@minimum_password_length} characters minimum"

          = f.submit "Create Account",
            class: "w-full bg-green-900 hover:bg-green-800 text-white py-3 rounded-lg transition duration-300"

          .text-center.mt-4
            span.text-sm.text-gray-600
              | Already have an account?

            = link_to " Sign in",
              new_session_path(resource_name),
              class: "text-sm text-green-700 font-semibold hover:underline ml-1"

javascript:
  document.addEventListener("DOMContentLoaded", function () {

    setTimeout(function () {
      document.querySelectorAll(".flash-message").forEach(function (el) {
        el.style.transition = "opacity 0.5s ease";
        el.style.opacity = "0";
        setTimeout(() => el.remove(), 500);
      });
    }, 3000);

    const familySelect = document.getElementById("family_select");
    const newFamilyInput = document.getElementById("new_family_input");

    if (familySelect && newFamilyInput) {

      familySelect.addEventListener("change", function () {
        if (this.value !== "") {
          newFamilyInput.value = "";
        }
      });

      newFamilyInput.addEventListener("input", function () {
        if (this.value.trim() !== "") {
          familySelect.selectedIndex = 0;
        }
      });

    }

  });