<h1 class="text-2xl font-semibold text-gray-800 mb-6">Create User</h1>

<%= form_with model: @user, class: "max-w-xl bg-white p-6 rounded-xl shadow-md space-y-5" do |f| %>

  <div>
    <%= f.label :first_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :first_name,
        class: "w-full rounded-lg border-gray-300 focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :last_name, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :last_name,
        class: "w-full rounded-lg border-gray-300 focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :identification_type, class: "block text-sm font-medium text-gray-700" %>

    <%= f.select :identification_type,
      User.identification_types.keys.map { |s| [s.humanize, s] },
      {},
      class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500"
    %>
  </div>
  <div>
    <%= f.label :identification_number, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :identification_number,
        class: "w-full rounded-lg border-gray-300 focus:border-indigo-500 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :status, class: "block text-sm font-medium text-gray-700" %>

    <%= f.select :status,
      User.statuses.keys.map { |s| [s.humanize, s] },
      {},
      class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500"
    %>
  </div>

  <div class="pt-4">
    <%= f.submit "Create User",
        class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2.5 rounded-lg transition" %>
  </div>

<% end %>